//
// TEMPLATE of credentials for Wake-on-LAN (ENABLE_WOL).
//
// Copy this file to `secrets.h` (same folder) and fill in the real values.
// `secrets.h` is in .gitignore and must NEVER be pushed to any repository:
// it holds the WiFi password and gets baked into the Pico's flash.
//
//   cp src/secrets.h.example src/secrets.h     # then edit src/secrets.h
//

#pragma once

// --- WiFi the Pico will connect to in order to send the magic packet ---
#define WIFI_SSID       "YOUR_SSID"
#define WIFI_PASS       "YOUR_WIFI_PASSWORD"

// --- PC to wake up ---
// MAC of the network card on the PC that has Wake-on-LAN enabled (usually the
// Ethernet one). Hex format with ':' or '-'. Example: "1C:69:7A:01:23:45".
// WoL targets the MAC, not the IP (we send a broadcast to 255.255.255.255).
// On Windows: `ipconfig /all` -> "Physical Address" of the adapter armed for WoL.
#define WOL_TARGET_MAC  "AA:BB:CC:DD:EE:FF"

// UDP port of the magic packet. De facto standard: 9 (7 is also used).
#define WOL_PORT        9
