//
// PLANTILLA de credencials per al Wake-on-LAN (ENABLE_WOL).
//
// Copia aquest fitxer a `secrets.h` (mateixa carpeta) i omple-hi els valors
// reals. `secrets.h` esta al .gitignore i NO s'ha de pujar MAI a cap repositori:
// conte la contrasenya del WiFi i s'incrusta a la flash de la Pico.
//
//   cp src/secrets.h.example src/secrets.h     # i edita src/secrets.h
//

#pragma once

// --- WiFi al qual es connectara la Pico per enviar el magic packet ---
#define WIFI_SSID       "EL_TEU_SSID"
#define WIFI_PASS       "LA_TEVA_CONTRASENYA_WIFI"

// --- PC a despertar ---
// MAC de la targeta de xarxa del PC que te el Wake-on-LAN activat (normalment
// l'Ethernet). Format hexadecimal amb ':' o '-'. Exemple: "1C:69:7A:01:23:45".
// El WoL s'adreca a la MAC, no a la IP (enviem broadcast 255.255.255.255).
// A Windows: `ipconfig /all` -> "Adreca fisica" de l'adaptador amb WoL armat.
#define WOL_TARGET_MAC  "AA:BB:CC:DD:EE:FF"

// Port UDP del magic packet. Estandard de facto: 9 (tambe s'usa 7).
#define WOL_PORT        9
